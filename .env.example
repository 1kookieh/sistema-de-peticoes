# Copie este arquivo para `.env` somente em ambiente local/controlado.
# Nunca versionar `.env` real.

EMAIL_ADVOGADO=advogado-responsavel@example.com

# Defina para proteger rotas sensíveis da API local.
# Quando vazio, a API mantém o modo local sem autenticação para demonstração.
API_TOKEN=
API_REQUIRE_TOKEN=false

API_ALLOWED_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000"]
REMETENTES_AUTORIZADOS=[]
MAX_JSON_BYTES=2097152
MAX_TEXT_CHARS=500000
GMAIL_LABEL_PROCESSADO=peticao-gerada
VALIDATION_PROFILE=judicial-inicial-jef

MCP_INBOX_PATH=./mcp_inbox.json
MCP_OUTBOX_PATH=./mcp_outbox.json
MCP_STATUS_PATH=./mcp_status.json

RETENTION_ENABLED=false
RETENTION_OUTPUT_DAYS=30
RETENTION_REPORTS_DAYS=30
RETENTION_QUEUE_DAYS=7
RETENTION_STATUS_DAYS=30

# IA/LLM: fluxo AI-first. Todo documento criado passa por provider LLM.
# Use LLM_PROVIDER=mock para testes/desenvolvimento, ollama para IA local
# sem chave externa, ou openai/anthropic em ambiente controlado.
LLM_REQUIRED=true
LLM_ALLOW_MOCK=true
LLM_ALLOW_CLIENT_PROVIDER=true
LLM_CLIENT_ALLOWED_PROVIDERS=mock,ollama,openai,anthropic
LLM_MODE=mock
LLM_PROVIDER=mock
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=6000
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_ATTEMPTS=2
LLM_REQUIRE_STRUCTURED_OUTPUT=true
LLM_FALLBACK_ENABLED=false
LLM_LOG_PROMPT=false

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Exemplos seguros:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434
#
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_API_KEY=
#
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
