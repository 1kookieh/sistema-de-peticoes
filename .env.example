# Copie este arquivo para `.env` e preencha com seus dados.
# O `.env` é ignorado pelo git.

# E-mail monitorado (remetente dos pedidos e destinatário das respostas).
EMAIL_ADVOGADO=seu-email@exemplo.com

# Label aplicado pelo orquestrador externo a threads já processadas (opcional).
GMAIL_LABEL_PROCESSADO=peticao-gerada
